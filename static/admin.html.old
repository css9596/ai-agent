<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>관리자 대시보드 - 개발 분석서 생성 시스템</title>
    <style>
        :root {
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --text: #1f2937;
            --text-light: #6b7280;
            --bg: #f3f4f6;
            --bg-white: #ffffff;
            --border: #e5e7eb;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto;
            background: var(--bg);
            color: var(--text);
        }

        .container {
            display: flex;
            min-height: 100vh;
        }

        /* 사이드바 */
        .sidebar {
            width: 250px;
            background: var(--bg-white);
            border-right: 1px solid var(--border);
            padding: 20px;
            position: sticky;
            top: 0;
            height: 100vh;
            overflow-y: auto;
        }

        .logo {
            font-size: 18px;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border);
        }

        .nav-items {
            list-style: none;
        }

        .nav-item {
            margin: 10px 0;
        }

        .nav-link {
            display: block;
            padding: 12px 16px;
            color: var(--text);
            text-decoration: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s;
            border-left: 3px solid transparent;
        }

        .nav-link:hover {
            background: var(--bg);
            color: var(--primary);
            border-left-color: var(--primary);
        }

        .nav-link.active {
            background: var(--bg);
            color: var(--primary);
            border-left-color: var(--primary);
            font-weight: 600;
        }

        /* 메인 콘텐츠 */
        .main {
            flex: 1;
            overflow-y: auto;
            padding: 30px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        h1 {
            font-size: 28px;
        }

        .status-badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-badge.healthy {
            background: #d1fae5;
            color: #065f46;
        }

        .status-badge.unhealthy {
            background: #fee2e2;
            color: #7f1d1d;
        }

        /* 패널 */
        .panel {
            background: var(--bg-white);
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 24px;
            border: 1px solid var(--border);
        }

        .panel h2 {
            font-size: 20px;
            margin-bottom: 20px;
            border-bottom: 2px solid var(--border);
            padding-bottom: 12px;
        }

        /* 통계 그리드 */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }

        .stat-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 12px;
            text-align: center;
        }

        .stat-card.success {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        }

        .stat-card.warning {
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        }

        .stat-card.danger {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        }

        .stat-value {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .stat-label {
            font-size: 13px;
            opacity: 0.9;
        }

        /* 테이블 */
        .table-container {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

        th {
            background: var(--bg);
            padding: 12px;
            text-align: left;
            font-weight: 600;
            border-bottom: 2px solid var(--border);
        }

        td {
            padding: 12px;
            border-bottom: 1px solid var(--border);
        }

        .btn-pagination {
            padding: 8px 16px;
            border: 1px solid var(--border);
            background: var(--bg-white);
            color: var(--text);
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 500;
            transition: all 0.3s;
        }

        .btn-pagination:hover:not(:disabled) {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .btn-pagination:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .download-link {
            color: var(--primary);
            text-decoration: none;
            cursor: pointer;
            font-size: 14px;
        }

        .download-link:hover {
            text-decoration: underline;
        }

        .status-badge {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-badge.completed,
        .status-badge.done {
            background: #d1fae5;
            color: #065f46;
        }

        .status-badge.running {
            background: #dbeafe;
            color: #0c4a6e;
        }

        .status-badge.pending {
            background: #fef3c7;
            color: #78350f;
        }

        .status-badge.failed {
            background: #fee2e2;
            color: #7f1d1d;
        }

        tr:hover {
            background: var(--bg);
        }

        .badge {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge.running {
            background: #bfdbfe;
            color: #1e40af;
        }

        .badge.completed {
            background: #d1fae5;
            color: #065f46;
        }

        .badge.failed {
            background: #fee2e2;
            color: #7f1d1d;
        }

        .badge.pending {
            background: #fef3c7;
            color: #7c2d12;
        }

        /* 로그 뷰어 */
        .log-viewer {
            background: #1e293b;
            color: #e2e8f0;
            padding: 16px;
            border-radius: 8px;
            font-family: 'Courier New', monospace;
            font-size: 12px;
            max-height: 400px;
            overflow-y: auto;
            margin-bottom: 16px;
        }

        .log-entry {
            margin: 4px 0;
            padding: 4px 0;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .log-time {
            color: #94a3b8;
        }

        .log-level-error {
            color: #f87171;
        }

        .log-level-warning {
            color: #fb923c;
        }

        .log-level-info {
            color: #60a5fa;
        }

        /* 버튼 */
        button {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
        }

        .btn-primary:hover {
            background: var(--primary-dark);
        }

        .btn-secondary {
            background: var(--bg);
            color: var(--text);
            border: 1px solid var(--border);
        }

        .btn-secondary:hover {
            background: var(--border);
        }

        /* 숨기기 */
        .hidden {
            display: none !important;
        }

        /* 반응형 */
        @media (max-width: 768px) {
            .sidebar {
                width: 200px;
                padding: 15px;
            }

            .main {
                padding: 15px;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .header {
                flex-direction: column;
                align-items: flex-start;
            }

            h1 {
                margin-bottom: 10px;
            }
        }

        /* 로딩 스피너 */
        .spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid var(--border);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- 사이드바 -->
        <div class="sidebar">
            <div class="logo">📊 Admin</div>
            <ul class="nav-items">
                <li class="nav-item">
                    <a class="nav-link active" onclick="showSection('dashboard')">대시보드</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" onclick="showSection('history')">분석 이력</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" onclick="showSection('logs')">로그</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" onclick="showSection('settings')">설정</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" onclick="showSection('health')">헬스 체크</a>
                </li>
            </ul>
        </div>

        <!-- 메인 콘텐츠 -->
        <div class="main">
            <!-- 대시보드 -->
            <section id="section-dashboard">
                <div class="header">
                    <h1>📊 대시보드</h1>
                    <span id="status-badge" class="status-badge healthy">
                        <span class="spinner"></span> 정상 작동 중
                    </span>
                </div>

                <div class="stats-grid" id="stats-container">
                    <div class="stat-card">
                        <div class="stat-value" id="stat-total">0</div>
                        <div class="stat-label">총 분석</div>
                    </div>
                    <div class="stat-card success">
                        <div class="stat-value" id="stat-completed">0</div>
                        <div class="stat-label">완료</div>
                    </div>
                    <div class="stat-card warning">
                        <div class="stat-value" id="stat-pending">0</div>
                        <div class="stat-label">대기 중</div>
                    </div>
                    <div class="stat-card danger">
                        <div class="stat-value" id="stat-failed">0</div>
                        <div class="stat-label">실패</div>
                    </div>
                </div>

                <div class="panel">
                    <h2>🔄 실시간 상태</h2>
                    <table>
                        <tr>
                            <th>항목</th>
                            <th>값</th>
                        </tr>
                        <tr>
                            <td>성공률</td>
                            <td id="queue-success-rate">0%</td>
                        </tr>
                        <tr>
                            <td>평균 분석 시간</td>
                            <td id="queue-avg-duration">0초</td>
                        </tr>
                        <tr>
                            <td>실행 중</td>
                            <td id="queue-running">0/3</td>
                        </tr>
                        <tr>
                            <td>대기 중</td>
                            <td id="queue-pending">0</td>
                        </tr>
                    </table>
                </div>
            </section>

            <!-- 분석 이력 -->
            <section id="section-history" class="hidden">
                <div class="header">
                    <h1>📋 분석 이력</h1>
                </div>

                <div class="panel">
                    <h2>최근 분석</h2>
                    <div class="table-container">
                        <table id="history-table">
                            <thead>
                                <tr>
                                    <th>파일명</th>
                                    <th>파일 크기</th>
                                    <th>상태</th>
                                    <th>소요 시간</th>
                                    <th>결과</th>
                                    <th>생성 일시</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>

                    <!-- 페이지네이션 -->
                    <div id="pagination" style="margin-top: 20px; display: flex; gap: 8px; justify-content: center; align-items: center;">
                        <button class="btn-pagination" id="prevPageBtn" onclick="loadHistoryPage(historyPage - 1)">← 이전</button>
                        <span id="pageInfo" style="color: var(--text-light); font-size: 14px;"></span>
                        <button class="btn-pagination" id="nextPageBtn" onclick="loadHistoryPage(historyPage + 1)">다음 →</button>
                    </div>
                </div>
            </section>

            <!-- 로그 -->
            <section id="section-logs" class="hidden">
                <div class="header">
                    <h1>📝 로그</h1>
                </div>

                <div class="panel">
                    <h2>최근 로그</h2>
                    <div class="log-viewer" id="log-viewer"></div>
                    <button class="btn-primary" onclick="loadLogs()">새로고침</button>
                </div>
            </section>

            <!-- 설정 -->
            <section id="section-settings" class="hidden">
                <div class="header">
                    <h1>⚙️ 설정</h1>
                </div>

                <div class="panel">
                    <h2>시스템 설정</h2>
                    <div id="settings-content" style="margin-top: 20px;">
                        <div style="margin-bottom: 20px;">
                            <strong>현재 설정 로드 중...</strong>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 헬스 체크 -->
            <section id="section-health" class="hidden">
                <div class="header">
                    <h1>🏥 헬스 체크</h1>
                </div>

                <div class="panel">
                    <h2>시스템 상태</h2>
                    <div id="health-content" style="margin-top: 20px;">
                        <div><strong>로드 중...</strong></div>
                    </div>
                </div>
            </section>
        </div>
    </div>

    <script>
        // 페이지네이션 상태
        let historyPage = 0;
        let historyLimit = 20;
        let historyTotal = 0;

        // 파일 크기 포맷팅
        function formatFileSize(bytes) {
            if (!bytes || bytes === 0) return '-';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
        }

        // 섹션 표시
        function showSection(sectionName) {
            // 모든 섹션 숨기기
            document.querySelectorAll('[id^="section-"]').forEach(el => {
                el.classList.add('hidden');
            });

            // 선택된 섹션 표시
            document.getElementById(`section-${sectionName}`).classList.remove('hidden');

            // 네비게이션 활성화
            document.querySelectorAll('.nav-link').forEach(el => {
                el.classList.remove('active');
            });
            event.target.classList.add('active');

            // 섹션별 데이터 로드
            if (sectionName === 'dashboard') {
                loadDashboard();
            } else if (sectionName === 'history') {
                loadHistory();
            } else if (sectionName === 'logs') {
                loadLogs();
            } else if (sectionName === 'settings') {
                loadSettings();
            } else if (sectionName === 'health') {
                loadHealth();
            }
        }

        // 대시보드 로드
        async function loadDashboard() {
            try {
                const response = await fetch('/api/admin/dashboard');
                const data = await response.json();

                document.getElementById('stat-total').textContent = data.statistics.total;
                document.getElementById('stat-completed').textContent = data.statistics.completed;
                document.getElementById('stat-pending').textContent = data.queue.pending;
                document.getElementById('stat-failed').textContent = data.statistics.failed;

                document.getElementById('queue-success-rate').textContent =
                    `${data.statistics.success_rate}%`;
                document.getElementById('queue-avg-duration').textContent =
                    `${data.statistics.avg_duration_seconds}초`;
                document.getElementById('queue-running').textContent =
                    `${data.queue.running}/${data.queue.max_concurrent}`;
                document.getElementById('queue-pending').textContent =
                    `${data.queue.pending}`;

            } catch (error) {
                console.error('대시보드 로드 실패:', error);
            }
        }

        // 분석 이력 페이지 로드
        async function loadHistoryPage(page) {
            if (page < 0) return;

            historyPage = page;
            const offset = page * historyLimit;

            try {
                const response = await fetch(`/api/history?limit=${historyLimit}&offset=${offset}`);
                const data = await response.json();

                historyTotal = data.total;
                const tbody = document.querySelector('#history-table tbody');
                tbody.innerHTML = '';

                data.analyses.forEach(analysis => {
                    const row = tbody.insertRow();

                    // 다운로드 링크
                    let downloadCell = '-';
                    if (analysis.output_file) {
                        const fileName = analysis.output_file.split('/').pop();
                        downloadCell = `<a class="download-link" href="/api/download/${fileName}" target="_blank">⬇️ ${fileName}</a>`;
                    }

                    row.innerHTML = `
                        <td>${analysis.file_name || '📝 텍스트 입력'}</td>
                        <td>${formatFileSize(analysis.file_size)}</td>
                        <td><span class="status-badge ${analysis.status}">${analysis.status}</span></td>
                        <td>${analysis.duration_seconds ? analysis.duration_seconds + '초' : '-'}</td>
                        <td>${downloadCell}</td>
                        <td>${new Date(analysis.created_at).toLocaleString('ko-KR')}</td>
                    `;
                });

                // 페이지네이션 버튼 상태 업데이트
                const prevBtn = document.getElementById('prevPageBtn');
                const nextBtn = document.getElementById('nextPageBtn');
                const pageInfo = document.getElementById('pageInfo');

                prevBtn.disabled = page === 0;
                nextBtn.disabled = offset + historyLimit >= historyTotal;
                pageInfo.textContent = `${offset + 1}-${Math.min(offset + historyLimit, historyTotal)} / 총 ${historyTotal}건`;

            } catch (error) {
                console.error('이력 로드 실패:', error);
            }
        }

        // 분석 이력 로드 (초기화)
        async function loadHistory() {
            historyPage = 0;
            await loadHistoryPage(0);
        }

        // 로그 로드
        async function loadLogs() {
            try {
                const response = await fetch('/api/admin/logs?limit=50');
                const data = await response.json();

                const logViewer = document.getElementById('log-viewer');
                logViewer.innerHTML = '';

                data.logs.forEach(log => {
                    const entry = document.createElement('div');
                    entry.className = `log-entry log-level-${log.level.toLowerCase()}`;
                    entry.innerHTML = `
                        <span class="log-time">${new Date(log.timestamp).toLocaleTimeString('ko-KR')}</span>
                        [${log.level}] ${log.message}
                    `;
                    logViewer.appendChild(entry);
                });

            } catch (error) {
                console.error('로그 로드 실패:', error);
            }
        }

        // 설정 로드
        async function loadSettings() {
            try {
                const response = await fetch('/api/admin/settings');
                const data = await response.json();

                const content = document.getElementById('settings-content');
                content.innerHTML = `
                    <div style="display: grid; gap: 20px;">
                        <div>
                            <h3>🤖 LLM 설정</h3>
                            <table style="width: 100%; margin-top: 10px;">
                                <tr><td style="padding: 8px; border-bottom: 1px solid var(--border);">Base URL</td><td style="padding: 8px; border-bottom: 1px solid var(--border);">${data.llm.base_url}</td></tr>
                                <tr><td style="padding: 8px; border-bottom: 1px solid var(--border);">모델</td><td style="padding: 8px; border-bottom: 1px solid var(--border);">${data.llm.model}</td></tr>
                                <tr><td style="padding: 8px; border-bottom: 1px solid var(--border);">모드</td><td style="padding: 8px; border-bottom: 1px solid var(--border);">${data.llm.mock_mode ? 'Mock' : 'Real'}</td></tr>
                            </table>
                        </div>
                        <div>
                            <h3>📊 분석 설정</h3>
                            <table style="width: 100%; margin-top: 10px;">
                                <tr><td style="padding: 8px; border-bottom: 1px solid var(--border);">최대 파일 크기</td><td style="padding: 8px; border-bottom: 1px solid var(--border);">${data.analysis.max_file_size_mb}MB</td></tr>
                                <tr><td style="padding: 8px; border-bottom: 1px solid var(--border);">최대 문서 토큰</td><td style="padding: 8px; border-bottom: 1px solid var(--border);">${data.analysis.max_document_tokens}</td></tr>
                                <tr><td style="padding: 8px; border-bottom: 1px solid var(--border);">최대 동시 분석</td><td style="padding: 8px; border-bottom: 1px solid var(--border);">${data.analysis.max_concurrent_analyses}</td></tr>
                                <tr><td style="padding: 8px; border-bottom: 1px solid var(--border);">타임아웃</td><td style="padding: 8px; border-bottom: 1px solid var(--border);">${data.analysis.timeout_minutes}분</td></tr>
                            </table>
                        </div>
                        <div>
                            <h3>💾 저장소 설정</h3>
                            <table style="width: 100%; margin-top: 10px;">
                                <tr><td style="padding: 8px; border-bottom: 1px solid var(--border);">보관 기간</td><td style="padding: 8px; border-bottom: 1px solid var(--border);">${data.storage.retention_days}일</td></tr>
                                <tr><td style="padding: 8px; border-bottom: 1px solid var(--border);">출력 디렉토리</td><td style="padding: 8px; border-bottom: 1px solid var(--border);">${data.storage.output_dir}</td></tr>
                            </table>
                        </div>
                    </div>
                `;

            } catch (error) {
                console.error('설정 로드 실패:', error);
            }
        }

        // 헬스 체크 로드
        async function loadHealth() {
            try {
                const response = await fetch('/api/health/detailed');
                const data = await response.json();

                const content = document.getElementById('health-content');
                content.innerHTML = `
                    <div style="display: grid; gap: 20px;">
                        <div style="padding: 12px; background: ${data.status === 'healthy' ? '#d1fae5' : '#fee2e2'}; border-radius: 8px;">
                            <strong>상태: ${data.status === 'healthy' ? '✅ 정상' : '⚠️ 문제'}</strong>
                        </div>

                        <div>
                            <h3>서비스 상태</h3>
                            <table style="width: 100%; margin-top: 10px;">
                                <tr>
                                    <td style="padding: 8px; border-bottom: 1px solid var(--border);">데이터베이스</td>
                                    <td style="padding: 8px; border-bottom: 1px solid var(--border);">
                                        <span class="badge ${data.services.database.status}">${data.services.database.status}</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 8px; border-bottom: 1px solid var(--border);">LLM</td>
                                    <td style="padding: 8px; border-bottom: 1px solid var(--border);">
                                        <span class="badge ${data.services.llm.status}">${data.services.llm.status}</span> (${data.services.llm.mode})
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 8px; border-bottom: 1px solid var(--border);">저장소</td>
                                    <td style="padding: 8px; border-bottom: 1px solid var(--border);">
                                        <span class="badge ${data.services.storage.status}">${data.services.storage.status}</span>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <div>
                            <h3>시스템 정보</h3>
                            <table style="width: 100%; margin-top: 10px;">
                                <tr>
                                    <td style="padding: 8px; border-bottom: 1px solid var(--border);">메모리</td>
                                    <td style="padding: 8px; border-bottom: 1px solid var(--border);">${data.system.memory.rss_mb}MB</td>
                                </tr>
                                <tr>
                                    <td style="padding: 8px; border-bottom: 1px solid var(--border);">디스크</td>
                                    <td style="padding: 8px; border-bottom: 1px solid var(--border);">${data.system.disk.used_gb}/${data.system.disk.total_gb}GB (${data.system.disk.percent}%)</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                `;

            } catch (error) {
                console.error('헬스 체크 로드 실패:', error);
            }
        }

        // 초기 로드
        window.onload = () => {
            loadDashboard();
            setInterval(loadDashboard, 5000); // 5초마다 갱신
        };
    </script>
</body>
</html>
