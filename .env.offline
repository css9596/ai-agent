# ========================================
# 오프라인 환경 설정 (.env 템플릿)
# ========================================
# 온라인 환경에서 처음 생성한 후
# 오프라인 환경에서는 이 파일을 .env로 복사해서 사용하세요.

# ========================================
# LLM 설정 (Docker Compose 내 Ollama 사용)
# ========================================
# 모드: "mock" (테스트용), "local" (Ollama), "claude" (API - 오프라인 불가)
LLM_MODE=local

# Ollama 로컬 서버 (Docker Compose 내부)
LLM_BASE_URL=http://ollama:11434/v1

# 모델 선택:
# - qwen2.5:7b (권장, ~5GB RAM)
# - llama3.2:3b (저사양 서버, ~2.5GB RAM)
# - llama3.3:70b (고사양 서버, ~40GB RAM)
LLM_MODEL=qwen2.5:7b

LLM_API_KEY=ollama

# Claude API (오프라인 환경에서는 사용 불가)
ANTHROPIC_API_KEY=

# ========================================
# 서버 설정
# ========================================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ========================================
# 파일 처리
# ========================================
MAX_FILE_SIZE_MB=50
MAX_DOCUMENT_TOKENS=100000
TEMP_UPLOAD_DIR=temp_uploads

# ========================================
# 프로젝트 관리 (Phase 6)
# ========================================
PROJECT_DIR=projects
MAX_PROJECT_SIZE_MB=500

# ========================================
# 분석 설정
# ========================================
MAX_CONCURRENT_ANALYSES=2
ANALYSIS_TIMEOUT_MINUTES=60
RETENTION_DAYS=30

# ========================================
# 경로 및 로그
# ========================================
OUTPUT_DIR=output
DATABASE_PATH=data/analysis_history.db
LOG_LEVEL=INFO
LOG_FILE=logs/analysis.log
LOG_FORMAT=json
